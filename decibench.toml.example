# Decibench local project configuration

[project]
name = "my-voice-agent"

[target]
default = "demo"

[auth]
# Manage secrets locally with:
#   decibench auth set openai
#   decibench auth set anthropic
#   decibench auth set gemini
#
# Environment variable fallback is also supported.
vapi_api_key = ""
retell_api_key = ""
openai_api_key = ""
anthropic_api_key = ""
gemini_api_key = ""

[providers]
tts = "edge-tts"
tts_voice = "en-US-JennyNeural"
stt = "faster-whisper:base"

# Deterministic only:
# judge = "none"

# OpenAI:
# judge = "openai-compat"
# judge_model = "gpt-5-mini"

# Anthropic:
# judge = "anthropic"
# judge_model = "claude-sonnet-4-20250514"

# Gemini:
# judge = "gemini"
# judge_model = "gemini-2.5-flash"

judge = "none"
judge_model = ""
judge_api_key = ""

[audio]
sample_rate = 16000
noise_profiles_dir = "./noise_profiles"

[evaluation]
runs_per_scenario = 1
judge_temperature = 0.0
timeout_seconds = 120

[scoring.weights]
task_completion = 0.25
latency = 0.20
audio_quality = 0.15
conversation = 0.15
robustness = 0.10
interruption = 0.10
compliance = 0.05

[ci]
min_score = 80
max_p95_latency_ms = 1500
fail_on_compliance_violation = true

[profiles.dev]
suite = "quick"
runs_per_scenario = 1

[profiles.ci]
suite = "standard"
runs_per_scenario = 3
min_score = 80
