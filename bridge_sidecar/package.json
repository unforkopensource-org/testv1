{
  "name": "decibench-bridge",
  "version": "1.0.0",
  "description": "Native voice agent bridge sidecar for Decibench. Runs official browser SDKs (Retell, Vapi) inside headless Chromium and exposes them to Decibench's Python orchestrator over a local WebSocket.",
  "license": "Apache-2.0",
  "repository": {
    "type": "git",
    "url": "https://github.com/decibench/decibench.git",
    "directory": "bridge_sidecar"
  },
  "type": "module",
  "main": "dist/server.js",
  "bin": {
    "decibench-bridge": "dist/server.js"
  },
  "engines": {
    "node": ">=20"
  },
  "files": [
    "dist/",
    "src/",
    "browser/",
    "README.md"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "start": "node dist/server.js",
    "lint": "tsc -p tsconfig.json --noEmit",
    "test": "node --test --import tsx test/"
  },
  "dependencies": {
    "playwright": "^1.49.0",
    "ws": "^8.18.0"
  },
  "devDependencies": {
    "@types/node": "^22.10.0",
    "@types/ws": "^8.5.13",
    "tsx": "^4.19.0",
    "typescript": "^5.6.0"
  }
}
